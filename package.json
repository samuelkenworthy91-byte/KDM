{
  "name": "lantern-deckbuilder",
  "version": "0.0.1",
  "private": true,
  "main": "electron/main.cjs",
  "description": "A roguelite deckbuilder inspired by dark monster‑hunting games.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "npm run build && electron .",
    "desktop:linux": "npm run build && electron-builder --linux AppImage",
    "package:steamos": "npm run desktop:linux"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.lantern.deckbuilder",
    "productName": "Lantern Deckbuilder",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Game",
      "artifactName": "LanternDeckbuilder.AppImage"
    }
  }
}
